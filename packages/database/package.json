{
  "name": "@puzzle-roll/database",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "ts-node --project tsconfig.json seed/index.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@puzzle-roll/shared": "workspace:*",
    "@types/node": "^22.0.0",
    "prisma": "^7.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma",
    "seed": "ts-node --project tsconfig.json seed/index.ts"
  }
}
