{
  "name": "puzzle-roll",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @puzzle-roll/api dev",
    "dev:mobile": "pnpm --filter @puzzle-roll/mobile dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "db:generate": "pnpm --filter @puzzle-roll/database db:generate",
    "db:migrate": "pnpm --filter @puzzle-roll/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @puzzle-roll/database db:migrate:deploy",
    "db:seed": "pnpm --filter @puzzle-roll/database db:seed",
    "db:reset": "pnpm --filter @puzzle-roll/database db:reset",
    "db:studio": "pnpm --filter @puzzle-roll/database db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}