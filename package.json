{
  "name": "puzzle-roll",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "db:generate": "pnpm --filter @puzzle-roll/database prisma generate",
    "db:migrate": "pnpm --filter @puzzle-roll/database prisma migrate dev",
    "db:seed": "pnpm --filter @puzzle-roll/database prisma db seed",
    "db:studio": "pnpm --filter @puzzle-roll/database prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0"
  }
}
